extends ../baseEmail

block content
  h4 Greetings, #{name}!
  p Welcome to Runway Coach App! We're excited to have you on board.
  p To get started, please verify your email address using the verification code below:
  
  .verification-code(style='text-align: center; margin: 30px 0; padding: 20px; background-color: #f3f4f6; border-radius: 8px; font-size: 32px; font-weight: bold; letter-spacing: 8px; color: #1f2937;')= code
  
  p Enter this code in the verification page to complete your email verification.
  
  p This verification code will expire in 24 hours.
  
  p If you didn't create an account with Runway Coach App, please ignore this email.
