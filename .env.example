# Application Configuration
NODE_ENV=development
HOST=http://localhost
PORT=8000
APP_NAME=runway-api

# Frontend Configuration
FRONT_END_URL=http://localhost:3000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/runway

# CORS Configuration
ORIGIN_REGEX=^http://localhost:.*
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d

# Email Configuration
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USER=your-email-username
MAIL_PASS=your-email-password
MAIL_FROM=noreply@runway.team

# External Auth Service (for future migration)
USE_EXTERNAL_AUTH=false
AUTH_SERVICE_URL=http://localhost:8000

# Event reminder job (optional; runs in-process cron)
# EVENT_REMINDER_MINUTES_BEFORE=60
# EVENT_REMINDER_CRON=*/15 * * * *

# Staging Environment (uncomment and modify as needed)
# NODE_ENV=staging
# HOST=https://staging.runway-api.com
# PORT=8080
# MONGO_URI=mongodb://staging-mongo:27017/runway
# ALLOWED_ORIGINS=https://staging.runway-app.com
