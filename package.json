{
  "name": "runway-api",
  "version": "0.1.0",
  "description": "Backend service for Runway following the Hemero API pattern",
  "main": "dist/server.js",
  "engines": {
    "node": ">=16.17.0"
  },
  "scripts": {
    "dev": "ts-node-dev --inspect=0.0.0.0:9230 --exit-child --respawn -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "email-templates": "^13.0.1",
    "express": "^4.18.2",
    "express-http-context": "^1.2.4",
    "express-validator": "^7.3.1",
    "helmet": "^7.0.0",
    "http-status": "^1.7.3",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.3.3",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.12",
    "pug": "^3.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/http-status": "^1.1.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.1",
    "@types/nodemailer": "^7.0.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.44.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.7",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.6"
  }
}
